# Generated by Cargo
# will have compiled files and executables
debug/
target/
**/Output/

# These are backup files generated by rustfmt
**/*.rs.bk

# Avoid terraform generated configuration for tests
**/*.tf
**/*.tar.gz
**/*.qcow2
**/*.pyc
**/*.tfstate*
**/mitogen*/*
**/.terraform/*

# Avoid code coverage and perf data files
*.data

# Used by integration tests
/integration_tests

# Packaging build artefacts
packaging/*/BUILD/*
packaging/*/BUILDROOT/*
*.rpm
*.swp

# Editor
.vscode
.data.json

tmp
docs/main*
